{
  "name": "cyberquest",
  "private": true,
  "version": "1.0.0",
  "description": "CyberQuest – frontend and backend",
  "scripts": {
    "dev": "concurrently -n f,b \"npm run dev --prefix frontend\" \"npm run dev --prefix backend\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "build": "npm run build --prefix frontend",
    "start:backend": "npm run start --prefix backend",
    "app:android": "npm run cap:android --prefix frontend",
    "app:ios": "npm run cap:ios --prefix frontend",
    "app:run:android": "npm run cap:run:android --prefix frontend",
    "app:run:ios": "npm run cap:run:ios --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
