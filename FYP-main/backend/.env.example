PORT=5000

# MongoDB Atlas (recommended)
# Atlas → Connect → Drivers → Node.js → copy connection string, then set database name to cyberquest:
# mongodb+srv://<username>:<password>@<cluster-host>/cyberquest?retryWrites=true&w=majority&appName=CyberQuest
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/cyberquest?retryWrites=true&w=majority&appName=CyberQuest

# Optional: override database name if your URI does not include one
# MONGODB_DB_NAME=cyberquest

# Local MongoDB (only if you run mongod on this machine)
# MONGODB_URI=mongodb://localhost:27017/cyberquest

JWT_SECRET=change-this-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
